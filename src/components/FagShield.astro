---
/**
 * Fag-ikon. Brukes inni skjold-formet tjeneste-kort.
 * (Skjoldformen kommer fra clip-path på kortet selv.)
 */
export interface Props {
  slug: string; // muring | puss | ildsted-og-skorstein | flis-vatrom-betong | restaurering
}
const { slug } = Astro.props;
---
<div class="fag-icon">
  {slug === 'muring' && (
    <svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linejoin="round" stroke-linecap="round" aria-hidden="true">
      <rect x="10" y="14" width="20" height="10" rx="1"/>
      <rect x="34" y="14" width="20" height="10" rx="1"/>
      <rect x="22" y="27" width="20" height="10" rx="1"/>
      <rect x="10" y="40" width="20" height="10" rx="1"/>
      <rect x="34" y="40" width="20" height="10" rx="1"/>
    </svg>
  )}
  {slug === 'puss' && (
    <svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linejoin="round" stroke-linecap="round" aria-hidden="true">
      <path d="M 14 50 L 26 38" />
      <path d="M 26 38 L 50 14 L 54 18 L 30 42 Z" />
      <path d="M 10 56 L 32 56" stroke-width="1.6" opacity=".6" />
      <path d="M 14 60 L 42 60" stroke-width="1.6" opacity=".4" />
    </svg>
  )}
  {slug === 'ildsted-og-skorstein' && (
    <svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linejoin="round" stroke-linecap="round" aria-hidden="true">
      <path d="M 32 12 Q 26 22 28 30 Q 22 28 22 36 Q 22 46 32 50 Q 42 46 42 36 Q 42 28 36 30 Q 38 22 32 12 Z" />
      <path d="M 16 54 L 48 54" />
      <path d="M 20 58 L 44 58" stroke-width="1.6" opacity=".5" />
    </svg>
  )}
  {slug === 'flis-vatrom-betong' && (
    <svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linejoin="round" stroke-linecap="round" aria-hidden="true">
      <rect x="12" y="12" width="18" height="18" rx="1.5"/>
      <rect x="34" y="12" width="18" height="18" rx="1.5"/>
      <rect x="12" y="34" width="18" height="18" rx="1.5"/>
      <rect x="34" y="34" width="18" height="18" rx="1.5"/>
      <path d="M 32 20 Q 26 28 32 32 Q 38 28 32 20 Z" fill="currentColor" opacity=".4" stroke="none" />
    </svg>
  )}
  {slug === 'restaurering' && (
    <svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linejoin="round" stroke-linecap="round" aria-hidden="true">
      <path d="M 14 52 L 14 28 Q 14 14 32 14 Q 50 14 50 28 L 50 52" />
      <path d="M 8 52 L 56 52" />
      <path d="M 26 28 L 26 38" opacity=".5" stroke-width="1.6"/>
      <path d="M 38 28 L 38 38" opacity=".5" stroke-width="1.6"/>
      <path d="M 32 22 L 32 44" opacity=".5" stroke-width="1.6"/>
    </svg>
  )}
</div>
