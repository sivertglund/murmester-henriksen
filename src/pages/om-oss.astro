---
import Layout from '../layouts/Layout.astro';
import { getOmOss, urlFor } from '../lib/sanity';
import { toHTML } from '@portabletext/to-html';

const om = await getOmOss();
const innholdHtml = om.innhold ? toHTML(om.innhold) : '';

const subheroImg = om.subheroBilde ? urlFor(om.subheroBilde).width(1400).url() : '/assets/vincent-portrait.jpg';
const portrettKortImg = om.portrettKortBilde ? urlFor(om.portrettKortBilde).width(800).url() : '/assets/vincent-workshop.jpg';
---
<Layout
  title="Om oss — Murmester Henriksen AS"
  description="Vincent Henriksen — mestermur, NM-sølv 2014, leder for det lokale murmesterlauget. Murmester Henriksen AS er etablert i Vear, Vestfold, siden 2008."
  activePage="om-oss"
>

<main>
  <section class="subhero subhero--portrait" style={`--subhero-img: url('${subheroImg}'); --subhero-pos: right top;`}>
    <div class="container subhero__inner">
      <p class="subhero__crumbs">
        <a href="/">Hjem</a>
        <span aria-hidden="true">/</span>
        <span>Om oss</span>
      </p>
      <p class="kicker kicker--light">{om.kicker}</p>
      <h1>{om.h1} <em>{om.h1Aksent}</em>{om.h1Slutt}</h1>
      <p class="subhero__lede">{om.subheroLede}</p>
    </div>
  </section>

  <section class="article">
    <div class="container article__inner">
      <div class="article__main">

        {innholdHtml ? (
          <Fragment set:html={innholdHtml} />
        ) : (
          <>
            <h2>Et lite firma</h2>
            <p>
              Murmester Henriksen AS er etablert i Vear, Vestfold, og har vært i
              drift siden 2008.
            </p>

            <h2>Vincent Henriksen</h2>

            <div class="portrait-card">
              <img src={portrettKortImg} alt={`${om.portrettKortNavn}, mestermur`} loading="lazy" decoding="async" />
              <div class="portrait-card__body">
                <strong>{om.portrettKortNavn}</strong>
                <span>{om.portrettKortRolle}</span>
              </div>
            </div>

            <p>
              Vincent er utdannet murer, har gått teknisk fagskole og har
              mestermurbrev. Han tok <strong>sølv i NM for unge murere i 2014</strong>,
              sitter i fylkets murerprøvenemnd og <strong>leder det lokale
              murmesterlauget</strong>.
            </p>
            <p>
              Han underviser også i faget, vurderer i det og tar svenneprøver.
            </p>

            <h2>Hva vi tar oppdrag på</h2>
            <p>
              Vi arbeider over hele Vestfold. Vi gjør kalkrestaurering på
              verneverdige bygg, teglforblending på nybygg, og det meste imellom:
              puss, peis, pipe, flis, våtrom, skifer og naturstein.
            </p>
            <p>
              Vi tar både private oppdrag og oppdrag for borettslag, bedrifter
              og offentlig sektor.
            </p>
          </>
        )}

      </div>

      <aside class="article__aside">
        <h3>Nøkkelfakta</h3>
        <p style="display:grid;gap:14px;font-size:.96rem;">
          {om.nokkelfakta.map((f) => (
            <span>
              <strong style="display:block;font-size:.72rem;letter-spacing:.14em;text-transform:uppercase;color:var(--ink-soft);margin-bottom:2px;">{f.label}</strong>
              {f.verdi}
            </span>
          ))}
        </p>

        <div class="related">
          <h4 class="kicker">Mer</h4>
          <ul>
            <li><a href="/tjenester/">Se tjenestene →</a></li>
            <li><a href="/kontakt">Ta kontakt →</a></li>
          </ul>
        </div>
      </aside>
    </div>
  </section>

</main>

</Layout>
