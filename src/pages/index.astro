---
import Layout from '../layouts/Layout.astro';
import IntroLogo from '../components/IntroLogo.astro';
import BrickRow from '../components/BrickRow.astro';
import BrandStripes from '../components/BrandStripes.astro';
import {
  getHero, getFounder, getProsjekter,
  getTestimonials, getAreas, getCTA, prosjektImageSrc, urlFor,
} from '../lib/sanity';
import { KATEGORIER } from '../lib/kategorier';
import FagShield from '../components/FagShield.astro';

const hero = await getHero();
const founder = await getFounder();
const prosjekter = await getProsjekter();
const testimonials = await getTestimonials();
const areas = await getAreas();
const cta = await getCTA();

const half = Math.ceil(prosjekter.length / 2);
const rad1 = prosjekter.slice(0, half);
const rad2 = prosjekter.slice(half);

// SVG icon set for chips
const chipIcons: Record<string, string> = {
  clock: '<circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/>',
  trophy: '<path d="M8 2l-3 6 4 .8M16 2l3 6-4 .8"/><circle cx="12" cy="15" r="6"/><path d="M9.5 13.5l1.7 1.7 3.3-3.3"/>',
  grid: '<rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/>',
  pin: '<path d="M21 10c0 7-9 13-9 13S3 17 3 10a9 9 0 1118 0z"/><circle cx="12" cy="10" r="3"/>',
};
---
<Layout
  title="Murmester Henriksen AS — Murmester i Vestfold · Tegl, puss, kalk, peis, flis"
  description="Murmester Henriksen AS leverer fem fagområder innen muring i hele Vestfold: muring, puss, ildsted og skorstein, flis/våtrom/betong, og restaurering. Drevet av murmester Vincent Henriksen, NM-sølv 2014."
  hasJsonLd={true}
>

<IntroLogo />

<a id="top"></a>

<!-- ===== Hero ===== -->
<section class="hero" id="hero">
  <div class="hero__sticky">
    <video
      id="heroVideo"
      class="hero__video"
      src="/assets/hero-wall-scrub-15s.mp4"
      muted
      playsinline
      preload="none"
      disableremoteplayback
      tabindex="-1"
      aria-hidden="true"></video>
    <div class="hero__overlay"></div>

    <div class="hero__content">
      <p class="hero__welcome-line">{hero.welcome}</p>

      <h1 class="hero__write" aria-label={`${hero.title} ${hero.titleEmphasis}`}>
        <span class="hero__write-text" id="heroWriteText">{hero.title} <em>{hero.titleEmphasis}</em></span>
      </h1>

      <div class="hero__cta">
        <a href="/kontakt" class="btn btn--primary">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="5" width="18" height="16" rx="2"/><path d="M16 3v4M8 3v4M3 11h18"/><path d="M9 16l2 2 4-4"/></svg>
          {hero.primaryCtaText}
        </a>
        <a href="/tjenester/" class="btn btn--ghost">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>
          {hero.secondaryCtaText}
        </a>
      </div>
    </div>
  </div>
</section>

<!-- ===== Founder + credentials ===== -->
<section class="founder" id="om">
  <div class="container founder__inner">
    <p class="kicker founder__kicker">{founder.kicker}</p>

    <div class="founder__hero">
      <figure class="founder__portrait">
        <img src={founder.portrett ? urlFor(founder.portrett).width(500).url() : '/assets/vincent-portrait.jpg'} alt="Murmester Vincent Henriksen" loading="lazy" decoding="async" />
        <div class="nm-medalje" aria-label="NM-sølv 2014">
          <svg viewBox="0 0 80 80" aria-hidden="true">
            <defs>
              <linearGradient id="medalje-grad" x1="0" y1="0" x2="0" y2="1">
                <stop offset="0%" stop-color="#e8c890"/>
                <stop offset="55%" stop-color="#c39054"/>
                <stop offset="100%" stop-color="#8a5a30"/>
              </linearGradient>
            </defs>
            <circle cx="40" cy="40" r="34" fill="url(#medalje-grad)" stroke="#fff" stroke-width="2"/>
            <circle cx="40" cy="40" r="28" fill="none" stroke="rgba(255,255,255,.4)" stroke-width="1"/>
          </svg>
          <span class="nm-medalje__txt">
            <span class="nm-medalje__nm">NM</span>
            <span class="nm-medalje__sylv">SØLV</span>
            <span class="nm-medalje__aar">2014</span>
          </span>
        </div>
      </figure>
      <div class="founder__copy">
        <h2 class="founder__title">{founder.tittel} <em>{founder.tittelAksent}</em>{founder.tittelSlutt}</h2>
        <p class="founder__lede">
          Murmester Henriksen AS ble etablert med et enkelt mål — å levere håndverk
          av høyeste kvalitet, kombinert med god kommunikasjon, faglig kompetanse
          og personlig oppfølging.
        </p>
        <p class="founder__lede">
          Som kunde møter du alltid fagpersonen som planlegger, prosjekterer
          og utfører arbeidet.
        </p>

        <a class="founder__more" href="/om-oss">
          {founder.lesMerTekst}
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>
    </div>

    <!-- Tegl-motif: continuous marquee som signatur i founder-seksjonen -->
    <BrickRow variant="marquee" tone="copper" rows={2} size="md" />

  </div>
</section>

<!-- ===== Mørk pussvegg-stage: tjenester → marquee → filosofi ===== -->
<div class="fp-stage">
<section class="services-list" id="tjenester">
  <div class="container services-list__head">
    <p class="kicker">Fem fagområder</p>
    <h2>Våre <em>tjenester</em></h2>
  </div>

  <div class="container">
    <ul class="fag-tiles">
      {KATEGORIER.map((k, i) => (
        <li class="fag-tile scroll-fade" style={`--i:${i}`}>
          <a class="fag-tile__link" href={`/tjenester/${k.slug}`}>
            <div class="fag-tile__emblem">
              <svg class="fag-tile__shield" viewBox="0 0 156 200" shape-rendering="geometricPrecision" aria-hidden="true">
                <path fill="#1F1F20" stroke="var(--copper-500)" stroke-width="2.5" stroke-linejoin="round" d="M 156 90.42 C 156 109.36, 151.85 126.98, 143.64 142.64 C 137.19 155.22, 128 166.62, 116.5 176.58 C 99.33 191.46, 82.17 198.48, 78.02 200 C 73.87 198.48, 56.69 191.46, 39.51 176.58 C 28.03 166.62, 18.83 155.22, 12.37 142.64 C 4.17 126.98, 0 109.36, 0 90.42 L 0 27.04 C 3.82 26.6, 11.48 25.5, 21.76 22.88 C 40.36 18.18, 59.83 10.28, 78.02 0 C 96.19 10.28, 115.66 18.18, 134.24 22.88 C 144.64 25.62, 152.18 26.6, 156 27.04 Z" />
              </svg>
              <div class="fag-tile__icon">
                <FagShield slug={k.slug} />
              </div>
            </div>
            <span class="fag-tile__title">{k.tittel}</span>
          </a>
        </li>
      ))}
    </ul>
  </div>

  <div class="container services-list__foot">
    <a class="btn btn--ghost-dark" href="/tjenester/">
      Se alle tjenester i detalj
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
    </a>
  </div>
</section>

<!-- ===== Prosjekt-marquee ===== -->
<section class="marquee marquee--on-wall" id="prosjekter-utvalg">
  <div class="container">
    <div class="marquee__head">
      <p class="kicker">Utvalgte arbeider</p>
      <h2 class="marquee__display">{areas.tittel} <em>{areas.tittelAksent}</em>{areas.tittelSlutt}</h2>
    </div>
  </div>

  <div class="marquee__rows">
    <div class="marquee__row" data-direction="right">
      <div class="marquee__track">
        {rad1.map((p) => (
          <figure class="marquee__item">
            <img src={prosjektImageSrc(p)} alt={`Prosjekt — ${p.tittel}`} loading="eager" decoding="async"/>
          </figure>
        ))}
      </div>
    </div>
    <div class="marquee__row" data-direction="left">
      <div class="marquee__track">
        {rad2.map((p) => (
          <figure class="marquee__item">
            <img src={prosjektImageSrc(p)} alt={`Prosjekt — ${p.tittel}`} loading="eager" decoding="async"/>
          </figure>
        ))}
      </div>
    </div>
  </div>

</section>
</div><!-- /.fp-stage -->

<!-- ===== Mester-sitat ===== -->
<section class="mester-sitat" id="filosofi">
  <div class="mester-sitat__bricks">
    <BrickRow variant="marquee" tone="subtle" rows={1} size="sm" />
  </div>
  <div class="container mester-sitat__inner">
    <blockquote class="mester-sitat__quote">
      <p class="scroll-fade">
        Godt håndverk handler om <em>kunnskap, erfaring, nøyaktighet og stolthet</em> i arbeidet.
      </p>
      <footer class="scroll-fade">
        <span class="mester-sitat__line" aria-hidden="true"></span>
        <strong>Vincent Henriksen</strong>
        <span class="mester-sitat__role">Murmester · Fagskoleingeniør · Oldermann · Faglig veileder</span>
      </footer>
    </blockquote>
  </div>
  <div class="mester-sitat__stripe-bot" aria-hidden="true"></div>
</section>


<!-- ===== Anmeldelser ===== -->
<section class="testimonials" id="anbefalinger">
  <div class="container testimonials__inner">
    <div class="testimonials__head">
      <p class="kicker">{testimonials.kicker}</p>
      <h2>{testimonials.tittel} <em>{testimonials.tittelAksent}</em>{testimonials.tittelSlutt}</h2>
    </div>

    {testimonials.sitater && testimonials.sitater.length > 0 && (
      <div class={`testimonials__grid testimonials__grid--${testimonials.sitater.length}`}>
        {testimonials.sitater.map((s) => {
          const stjerner = s.stjerner ?? 5;
          const sitatMarkup = (
            <>
              <div class="quote__stars" aria-label={`${stjerner} av 5 stjerner`}>
                {'★'.repeat(stjerner)}<span class="quote__stars-off" aria-hidden="true">{'★'.repeat(5 - stjerner)}</span>
              </div>
              <blockquote class="quote__body"><p>{s.tekst}</p></blockquote>
              <figcaption class="quote__meta">
                <strong class="quote__navn">{s.navn}</strong>
                <span class="quote__submeta">
                  {s.meta && <span>{s.meta}</span>}
                  {s.dato && <span>{s.dato}</span>}
                </span>
              </figcaption>
              {s.kildeUrl && (
                <span class="quote__source">
                  Se på Google
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7 17L17 7M17 7H7M17 7v10"/></svg>
                </span>
              )}
            </>
          );
          return s.kildeUrl ? (
            <a class="quote quote--link" href={s.kildeUrl} target="_blank" rel="noopener nofollow" aria-label={`Anmeldelse fra ${s.navn} på Google`}>
              {sitatMarkup}
            </a>
          ) : (
            <figure class="quote">{sitatMarkup}</figure>
          );
        })}
      </div>
    )}

    <!-- Bidra-panel: QR + "Gi en anmeldelse på Google" -->
    <div class="review-cta">
      <div class="review-cta__body">
        <p class="kicker">Bidra selv</p>
        <h3 class="review-cta__h3">Har vi jobbet for deg?</h3>
        <p class="review-cta__lede">Vi setter enormt pris på en anmeldelse — det hjelper både oss og neste kunde.</p>
        <a class="btn btn--primary review-cta__btn" href={testimonials.giAnmeldelseUrl} target="_blank" rel="noopener">
          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
          Gi en anmeldelse på Google
        </a>
      </div>
      <div class="review-cta__qr" aria-hidden="true">
        <div class="review-cta__qr-frame">
          <img src="/assets/anmeldelser/qr-google-review.svg" alt="" width="140" height="140" />
        </div>
        <p class="review-cta__qr-caption">Skann for å gi en anmeldelse</p>
      </div>
    </div>

  </div>
</section>

<!-- ===== CTA-strip før kart ===== -->
<section class="cta-strip section--dark">
  <div class="cta-strip__bricks">
    <BrickRow variant="marquee" tone="copper" rows={1} size="sm" />
  </div>
  <div class="container cta-strip__inner">
    <p class="kicker kicker--light">{cta.kicker}</p>
    <h2>{cta.tittel} <em>{cta.tittelAksent}</em>{cta.tittelSlutt}</h2>
    <div class="cta-strip__btns">
      <a href="/kontakt" class="btn btn--primary btn--lg">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="5" width="18" height="16" rx="2"/><path d="M16 3v4M8 3v4M3 11h18"/><path d="M9 16l2 2 4-4"/></svg>
        {cta.primarBtnTekst}
      </a>
      <a href="tel:+4795523763" class="btn btn--ghost btn--lg">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92V21a1 1 0 01-1.11 1A19 19 0 012 4.11 1 1 0 013 3h4.09a1 1 0 011 .75l1 4a1 1 0 01-.27 1L7 10.5a16 16 0 006.5 6.5l1.75-1.75a1 1 0 011-.27l4 1a1 1 0 01.75 1z"/></svg>
        {cta.ringBtnTekst}
      </a>
    </div>
  </div>
</section>

<script is:inline>
  // Hero-video: preload="none" + opacity:0 i CSS sikrer at ingen frame
  // vises før play() er kalt og første frame er dekodet. Video gjøres
  // synlig først via .is-playing klassen — fyrer på 'playing' event,
  // som garantert er etter frame 0 er rendret.
  (function () {
    var video = document.getElementById('heroVideo');
    if (!video) return;
    var overlay = document.getElementById('introOverlay');
    var started = false;
    video.addEventListener('playing', function () {
      video.classList.add('is-playing');
    }, { once: true });
    function start() {
      if (started) return;
      started = true;
      // Last inn videoen først (preload='none' krevde dette)
      try { video.load(); } catch (e) {}
      try { video.currentTime = 0; } catch (e) {}
      var p = video.play();
      if (p && typeof p.catch === 'function') {
        p.catch(function () {
          var retry = function () {
            video.play().catch(function () {});
            document.removeEventListener('click', retry);
            document.removeEventListener('touchstart', retry);
          };
          document.addEventListener('click', retry, { once: true });
          document.addEventListener('touchstart', retry, { once: true });
        });
      }
    }
    // Start videoen ~3.5s ut i page-load. Da har videoen spilt ~1.9s
    // av 15s når intro-overlay (5.4s) er ferdig — bare 10-15% av muren
    // er bygd opp ved første blikk, fortsetter naturlig derfra.
    setTimeout(start, 3500);
  })();
</script>

</Layout>
