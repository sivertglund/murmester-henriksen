---
import Layout from '../layouts/Layout.astro';
import { getHero, getTjenester, getProsjekter, prosjektImageSrc } from '../lib/sanity';

const hero = await getHero();
const tjenester = await getTjenester();
const prosjekter = await getProsjekter();

// Split projects into two rows for the marquee (alternating direction).
const half = Math.ceil(prosjekter.length / 2);
const rad1 = prosjekter.slice(0, half);
const rad2 = prosjekter.slice(half);
---
<Layout
  title="Murmester Henriksen AS — Mestermur i Vestfold · Tegl, puss, kalk, peis"
  description="Murmester Henriksen AS er en mestermur i Vear som arbeider med teglforblending, puss, hydraulisk kalkrestaurering, peis og pipe i hele Vestfold. Etablert 2008. NM-sølv 2014."
  hasJsonLd={true}
>

<a id="top"></a>

<!-- ===== Hero ===== -->
<section class="hero" id="hero">
  <div class="hero__sticky">
    <video
      id="heroVideo"
      class="hero__video"
      src="/assets/hero-wall-scrub-15s.mp4"
      muted
      playsinline
      autoplay
      preload="auto"
      disableremoteplayback
      tabindex="-1"
      aria-hidden="true"
      poster="/assets/hero-wall-poster.jpg"></video>
    <div class="hero__overlay"></div>

    <div class="hero__content">
      <p class="hero__welcome">{hero.welcome}</p>

      <h1 class="hero__write" aria-label={`${hero.title} ${hero.titleEmphasis}`}>
        <span class="hero__write-text" id="heroWriteText">{hero.title} <em>{hero.titleEmphasis}</em></span>
        <span class="hero__pen" id="heroPen" aria-hidden="true"></span>
      </h1>

      <a href="/kontakt" class="hero__signature">
        <span class="hero__signature-text">{hero.signature}</span>
      </a>

      <div class="hero__cta">
        <a href="/kontakt" class="btn btn--primary">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="5" width="18" height="16" rx="2"/><path d="M16 3v4M8 3v4M3 11h18"/><path d="M9 16l2 2 4-4"/></svg>
          {hero.primaryCtaText}
        </a>
        <a href="/tjenester/" class="btn btn--ghost">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>
          {hero.secondaryCtaText}
        </a>
      </div>
    </div>
  </div>
</section>

<!-- ===== Founder + credentials ===== -->
<section class="founder" id="om">
  <div class="container founder__inner">
    <p class="kicker founder__kicker">Mestermur · Vear, Vestfold · siden 2008</p>

    <div class="founder__hero">
      <figure class="founder__portrait">
        <img src="/assets/vincent-portrait.jpg" alt="Mestermur Vincent Henriksen" loading="lazy" decoding="async" />
      </figure>
      <div class="founder__copy">
        <h2 class="founder__title">Murmester <em>Henriksen</em>.</h2>
        <p class="founder__lede">
          Velkommen til <strong>Murmester Henriksen AS</strong>, din pålitelige
          partner for mur, puss, flis, naturstein, peis, pipe og mer.
          Med over <em>15 års bransjeerfaring</em> leverer vi kvalitetstjenester
          til både privat- og næringskunder.
        </p>

        <ul class="founder__chips">
          <li class="chip">
            <span class="chip__icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></svg>
            </span>
            <div class="chip__body">
              <span class="chip__num">15+</span>
              <span class="chip__label">års erfaring</span>
            </div>
          </li>
          <li class="chip">
            <span class="chip__icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M8 2l-3 6 4 .8M16 2l3 6-4 .8"/><circle cx="12" cy="15" r="6"/><path d="M9.5 13.5l1.7 1.7 3.3-3.3"/></svg>
            </span>
            <div class="chip__body">
              <span class="chip__num">2014</span>
              <span class="chip__label">NM-sølv i muring</span>
            </div>
          </li>
          <li class="chip">
            <span class="chip__icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>
            </span>
            <div class="chip__body">
              <span class="chip__num">9</span>
              <span class="chip__label">fagområder</span>
            </div>
          </li>
          <li class="chip">
            <span class="chip__icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13S3 17 3 10a9 9 0 1118 0z"/><circle cx="12" cy="10" r="3"/></svg>
            </span>
            <div class="chip__body">
              <span class="chip__num">Vestfold</span>
              <span class="chip__label">hele fylket</span>
            </div>
          </li>
        </ul>

        <a class="founder__more" href="/om-oss">
          Les mer om oss
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>
    </div>

    <!-- Tegl-rad: bricks "legges" når seksjonen kommer i syne -->
    <svg class="founder__bricks" viewBox="0 0 360 60" fill="none" preserveAspectRatio="xMidYMid meet" aria-hidden="true">
      <g class="brick-row">
        <rect x="2"   y="36" width="56" height="20" rx="2"/>
        <rect x="62"  y="36" width="56" height="20" rx="2"/>
        <rect x="122" y="36" width="56" height="20" rx="2"/>
        <rect x="182" y="36" width="56" height="20" rx="2"/>
        <rect x="242" y="36" width="56" height="20" rx="2"/>
        <rect x="302" y="36" width="56" height="20" rx="2"/>
      </g>
      <g class="brick-row brick-row--top">
        <rect x="32"  y="12" width="56" height="20" rx="2"/>
        <rect x="92"  y="12" width="56" height="20" rx="2"/>
        <rect x="152" y="12" width="56" height="20" rx="2"/>
        <rect x="212" y="12" width="56" height="20" rx="2"/>
        <rect x="272" y="12" width="56" height="20" rx="2"/>
      </g>
    </svg>
  </div>
</section>

<!-- ===== Tjenester: kompakt liste — kort om hvert fagområde ===== -->
<section class="services-list" id="tjenester">
  <div class="container services-list__head">
    <h2>Våre <em>tjenester</em></h2>
    <p class="lead">
      For oss er det viktig å levere enestående resultater.
      Vi tilbyr et bredt spekter av tjenester:
    </p>
  </div>

  <div class="container">
    <ul class="svc-list">
      {tjenester.map((t) => (
        <li>
          <a class="svc-row" href={`/tjenester/${t.slug.current}`}>
            <span class="svc-row__num">{t.nummer}</span>
            <span class="svc-row__title" set:html={t.tittel} />
            <span class="svc-row__arrow" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </span>
          </a>
        </li>
      ))}
    </ul>
  </div>

  <div class="container services-list__foot">
    <a class="btn btn--ghost-dark" href="/tjenester/">
      Se alle tjenester i detalj
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
    </a>
  </div>
</section>

<!-- ===== Prosjekt-marquee ===== -->
<section class="marquee" id="prosjekter-utvalg">
  <div class="container">
    <div class="marquee__head">
      <h2 class="display">Prosjekter</h2>
    </div>
  </div>

  <div class="marquee__rows">
    <div class="marquee__row" data-direction="right">
      <div class="marquee__track">
        {rad1.map((p) => (
          <figure class="marquee__item">
            <img src={prosjektImageSrc(p)} alt={`Prosjekt — ${p.tittel}`} loading="eager" decoding="async"/>
          </figure>
        ))}
      </div>
    </div>
    <div class="marquee__row" data-direction="left">
      <div class="marquee__track">
        {rad2.map((p) => (
          <figure class="marquee__item">
            <img src={prosjektImageSrc(p)} alt={`Prosjekt — ${p.tittel}`} loading="eager" decoding="async"/>
          </figure>
        ))}
      </div>
    </div>
  </div>

  <div class="container marquee__foot">
    <a href="/prosjekter" class="btn btn--primary marquee__cta">
      Se alle prosjekter
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
    </a>
  </div>
</section>

<!-- ===== Testimonials — hva kunder sier ===== -->
<section class="testimonials" id="anbefalinger">
  <div class="container testimonials__inner">
    <div class="testimonials__head">
      <p class="kicker">Anbefalinger</p>
      <h2>Hva kundene <em>faktisk sier</em>.</h2>
    </div>

    <div class="testimonials__grid">
      <figure class="quote quote--empty" aria-hidden="true"></figure>
      <figure class="quote quote--empty" aria-hidden="true"></figure>
      <figure class="quote quote--empty" aria-hidden="true"></figure>
    </div>

  </div>
</section>

<!-- ===== Serviceområde ===== -->
<section class="areas" id="omrader">
  <div class="container areas__inner">
    <h2>Vi dekker hele <em>Vestfold</em>.</h2>
    <ul class="areas__list">
      <li>Hvasser</li>
      <li>Nøtterøy</li>
      <li>Tønsberg</li>
      <li>Larvik</li>
      <li>Tjøme</li>
      <li>Sandefjord</li>
      <li>Horten</li>
      <li>Skoppum</li>
      <li>Sande</li>
      <li>Stokke</li>
    </ul>
  </div>
</section>

<!-- ===== CTA-strip før kart ===== -->
<section class="cta-strip section--dark">
  <div class="container cta-strip__inner">
    <p class="kicker kicker--light">Klar for å starte?</p>
    <h2>La oss <em>se på jobben</em>.</h2>
    <div class="cta-strip__btns">
      <a href="/kontakt" class="btn btn--primary btn--lg">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="5" width="18" height="16" rx="2"/><path d="M16 3v4M8 3v4M3 11h18"/><path d="M9 16l2 2 4-4"/></svg>
        Be om befaring
      </a>
      <a href="tel:+4795523763" class="btn btn--ghost btn--lg">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92V21a1 1 0 01-1.11 1A19 19 0 012 4.11 1 1 0 013 3h4.09a1 1 0 011 .75l1 4a1 1 0 01-.27 1L7 10.5a16 16 0 006.5 6.5l1.75-1.75a1 1 0 011-.27l4 1a1 1 0 01.75 1z"/></svg>
        Ring 955 23 763
      </a>
    </div>
  </div>
</section>

</Layout>
