---
import Layout from '../../layouts/Layout.astro';
import BrickRow from '../../components/BrickRow.astro';
import FagShield from '../../components/FagShield.astro';
import { KATEGORIER } from '../../lib/kategorier';
---
<Layout
  title="Tjenester — Murmester Henriksen AS"
  description="Murmester Henriksen AS leverer fem hovedfag innen muring: muring, puss, ildsted og skorstein, flis/våtrom/betong, og restaurering."
  activePage="tjenester"
>

<main>
  <section class="tj-intro">
    <div class="container tj-intro__inner">
      <p class="subhero__crumbs">
        <a href="/">Hjem</a>
        <span aria-hidden="true">/</span>
        <span>Tjenester</span>
      </p>
      <div class="tj-intro__head">
        <p class="kicker">Faget</p>
        <h1 class="tj-intro__h1">
          Fem fag, <em>samme hånd</em>.
        </h1>
        <p class="tj-intro__lede">
          Fra grunnmur og teglforblending til antikvarisk kalkrestaurering —
          alt utført av samme mester, fra første befaring til ferdig fuge.
        </p>
      </div>
    </div>
    <div class="tj-intro__bricks">
      <BrickRow variant="marquee" tone="subtle" rows={2} size="md" />
    </div>
  </section>

  <section class="tj-cards">
    <div class="container">
      <ul class="tj-cards__grid">
        {KATEGORIER.map((k, i) => (
          <li class="tj-card scroll-fade" style={`--i:${i}`}>
            <a href={`/tjenester/${k.slug}`} class="tj-card__link">
              <div class="tj-card__emblem">
                <FagShield slug={k.slug} />
                <span class="tj-card__num">{k.nummer}</span>
              </div>
              <h2 class="tj-card__title">{k.tittel}</h2>
              <p class="tj-card__lede">{k.kortLede}</p>
              <div class="tj-card__foot">
                <span class="tj-card__count">{k.underkategorier.length} leveranser</span>
                <span class="tj-card__arrow" aria-hidden="true">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                </span>
              </div>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <section class="cta-strip section--dark">
    <div class="cta-strip__bricks">
      <BrickRow variant="marquee" tone="copper" rows={1} size="sm" />
    </div>
    <div class="container cta-strip__inner">
      <p class="kicker kicker--light">Klar for å starte?</p>
      <h2>La oss <em>se på jobben</em>.</h2>
      <p class="cta-strip__lede">Vi gir et tydelig, skriftlig prisanslag. Uforpliktende.</p>
      <div class="cta-strip__btns">
        <a href="/kontakt" class="btn btn--primary btn--lg">Kontakt oss</a>
        <a href="tel:+4795523763" class="btn btn--ghost btn--lg">Ring 955 23 763</a>
      </div>
    </div>
  </section>
</main>

</Layout>
