---
import Layout from '../../layouts/Layout.astro';
import { KATEGORIER } from '../../lib/kategorier';

const totalLeveranser = KATEGORIER.reduce((sum, k) => sum + k.underkategorier.length, 0);
---
<Layout
  title="Tjenester — Murmester Henriksen AS"
  description="Murmester Henriksen AS leverer fem hovedfag innen muring: muring, puss, ildsted og skorstein, flis/våtrom/betong, og restaurering."
  activePage="tjenester"
>

<main>
  <section class="tj-intro">
    <div class="container tj-intro__inner">
      <p class="subhero__crumbs">
        <a href="/">Hjem</a>
        <span aria-hidden="true">/</span>
        <span>Tjenester</span>
      </p>
      <div class="tj-intro__head">
        <p class="kicker">Faget</p>
        <h1 class="tj-intro__h1">
          Murmesterens <em>fem fag</em>
        </h1>
        <p class="tj-intro__lede">
          Fra grunnmur og teglforblending til antikvarisk kalkrestaurering —
          alt utført av samme mester, fra første befaring til ferdig fuge.
        </p>
        <div class="tj-intro__count">
          <span class="tj-intro__count-num">{totalLeveranser}</span>
          <span class="tj-intro__count-label">leveranser fordelt på fem fag</span>
        </div>
      </div>
    </div>
  </section>

  <section class="tj-list">
    <span class="tj-list__stripe" aria-hidden="true"></span>
    <div class="container">
      <ul class="tj-list__items">
        {KATEGORIER.map((k, i) => (
          <li class="tj-row scroll-fade" style={`--i:${i}`}>
            <a class="tj-row__link" href={`/tjenester/${k.slug}`}>
              <span class="tj-row__indicator" aria-hidden="true"></span>
              <span class="tj-row__num">{k.nummer}</span>
              <span class="tj-row__main">
                <span class="tj-row__head">
                  <h2 class="tj-row__name">{k.tittel}</h2>
                  <span class="tj-row__meta">
                    <span class="tj-row__count">{k.underkategorier.length} leveranser</span>
                    <span class="tj-row__arrow" aria-hidden="true">→</span>
                  </span>
                </span>
                <span class="tj-row__lede">{k.kortLede}</span>
                <span class="tj-row__leveranser">
                  {k.underkategorier.map((u, j) => (
                    <span class="tj-row__lv" style={`--j:${j}`}>{u.navn}</span>
                  ))}
                </span>
              </span>
            </a>
            <span class="tj-row__line" aria-hidden="true"></span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <section class="cta-strip section--dark">
    <div class="container cta-strip__inner">
      <p class="kicker kicker--light">Klar for å starte?</p>
      <h2>La oss <em>se på jobben</em>.</h2>
      <p class="cta-strip__lede">Vi gir et tydelig, skriftlig prisanslag. Uforpliktende.</p>
      <div class="cta-strip__btns">
        <a href="/kontakt" class="btn btn--primary btn--lg">Kontakt oss</a>
        <a href="tel:+4795523763" class="btn btn--ghost btn--lg">Ring 955 23 763</a>
      </div>
    </div>
  </section>
</main>

</Layout>
