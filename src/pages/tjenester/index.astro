---
import Layout from '../../layouts/Layout.astro';
import { KATEGORIER } from '../../lib/kategorier';
---
<Layout
  title="Tjenester — Murmester Henriksen AS"
  description="Murmester Henriksen AS leverer fem hovedfag innen muring: muring, puss, ildsted og skorstein, flis/våtrom/betong, og restaurering."
  activePage="tjenester"
>

<main>
  <section class="tj-hub-hero">
    <div class="container tj-hub-hero__inner">
      <p class="subhero__crumbs">
        <a href="/">Hjem</a>
        <span aria-hidden="true">/</span>
        <span>Tjenester</span>
      </p>
      <p class="kicker">Faget</p>
      <h1 class="tj-hub-hero__h1">
        Murmesterens <em>fem fag</em>
      </h1>
      <p class="tj-hub-hero__lede">
        Fra grunnmur og teglforblending til antikvarisk kalkrestaurering —
        alt utført av samme mester, fra første befaring til ferdig fuge.
      </p>
    </div>
  </section>

  <section class="tj-hub">
    <div class="container">
      <ul class="tj-hub__grid">
        {KATEGORIER.map((k) => (
          <li class="tj-hub__item scroll-fade">
            <a href={`/tjenester/${k.slug}`} class="tj-hub__card">
              <div class="tj-hub__media">
                <img src={k.heroBilde} alt="" loading="lazy" decoding="async" />
                <span class="tj-hub__num" aria-hidden="true">{k.nummer}</span>
              </div>
              <div class="tj-hub__body">
                <h2 class="tj-hub__title">{k.tittel}</h2>
                <p class="tj-hub__lede">{k.kortLede}</p>
                <div class="tj-hub__foot">
                  <span class="tj-hub__count">{k.underkategorier.length} leveranser</span>
                  <span class="tj-hub__arrow" aria-hidden="true">→</span>
                </div>
              </div>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <section class="cta-strip section--dark">
    <div class="container cta-strip__inner">
      <p class="kicker kicker--light">Klar for å starte?</p>
      <h2>La oss <em>se på jobben</em>.</h2>
      <p class="cta-strip__lede">Vi gir et tydelig, skriftlig prisanslag. Uforpliktende.</p>
      <div class="cta-strip__btns">
        <a href="/kontakt" class="btn btn--primary btn--lg">Kontakt oss</a>
        <a href="tel:+4795523763" class="btn btn--ghost btn--lg">Ring 955 23 763</a>
      </div>
    </div>
  </section>
</main>

</Layout>
