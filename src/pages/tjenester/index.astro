---
import Layout from '../../layouts/Layout.astro';
import BrickRow from '../../components/BrickRow.astro';
import FagShield from '../../components/FagShield.astro';
import { KATEGORIER } from '../../lib/kategorier';
---
<Layout
  title="Tjenester — Murmester Henriksen AS"
  description="Murmester Henriksen AS leverer fem hovedfag innen muring: muring, puss, ildsted og skorstein, flis/våtrom/betong, og restaurering."
  activePage="tjenester"
>

<main>
  <!-- SVG-clipPath som matcher Henriksen-logoens faktiske skjold-form
       (utledet fra logo-pathen, rotert 90°, normalisert til 0-1) -->
  <svg width="0" height="0" style="position:absolute" aria-hidden="true">
    <defs>
      <clipPath id="shieldClip" clipPathUnits="objectBoundingBox">
        <path d="M 1 0.4521 C 1 0.5468, 0.9734 0.6349, 0.9208 0.7132 C 0.8794 0.7761, 0.8205 0.8331, 0.7468 0.8829 C 0.6367 0.9573, 0.5267 0.9924, 0.5001 1 C 0.4735 0.9924, 0.3634 0.9573, 0.2533 0.8829 C 0.1797 0.8331, 0.1207 0.7761, 0.0793 0.7132 C 0.0267 0.6349, 0 0.5468, 0 0.4521 L 0 0.1352 C 0.0245 0.133, 0.0736 0.1275, 0.1395 0.1144 C 0.2587 0.0909, 0.3835 0.0514, 0.5001 0 C 0.6166 0.0514, 0.7414 0.0909, 0.8605 0.1144 C 0.9272 0.1281, 0.9755 0.133, 1 0.1352 Z" />
      </clipPath>
    </defs>
  </svg>

  <div class="tj-stage">
  <section class="tj-cards tj-cards--dark">
    <div class="tj-cards__bricks tj-cards__bricks--top" aria-hidden="true">
      <BrickRow variant="marquee" tone="copper" rows={1} size="sm" />
    </div>

    <div class="container">
      <header class="tj-header">
        <p class="kicker kicker--light">Faget</p>
        <h1 class="tj-header__title">Våre tjenester</h1>
        <p class="tj-header__sub">Fem fag — utforsk hva som leveres innenfor hver.</p>
      </header>

      <ul class="tj-cards__grid">
        {KATEGORIER.map((k, i) => (
          <li class="tj-card scroll-fade" style={`--i:${i}`}>
            <a href={`/tjenester/${k.slug}`} class="tj-card__link">
              <!-- Skjold-outline med pixel-viewBox 156×200 så ingen non-uniform stretching skjer -->
              <svg class="tj-card__frame" viewBox="0 0 156 200" shape-rendering="geometricPrecision" aria-hidden="true">
                <path
                  fill="none"
                  stroke="currentColor"
                  stroke-width="3"
                  stroke-linejoin="round"
                  d="M 156 90.42 C 156 109.36, 151.85 126.98, 143.64 142.64 C 137.19 155.22, 128 166.62, 116.5 176.58 C 99.33 191.46, 82.17 198.48, 78.02 200 C 73.87 198.48, 56.69 191.46, 39.51 176.58 C 28.03 166.62, 18.83 155.22, 12.37 142.64 C 4.17 126.98, 0 109.36, 0 90.42 L 0 27.04 C 3.82 26.6, 11.48 25.5, 21.76 22.88 C 40.36 18.18, 59.83 10.28, 78.02 0 C 96.19 10.28, 115.66 18.18, 134.24 22.88 C 144.64 25.62, 152.18 26.6, 156 27.04 Z"
                />
              </svg>
              <div class="tj-card__inner">
                <FagShield slug={k.slug} />
                <h2 class="tj-card__title">{k.tittel}</h2>
                <p class="tj-card__lede">{k.kortLede}</p>
                <span class="tj-card__count">{k.underkategorier.length} leveranser →</span>
              </div>
            </a>
          </li>
        ))}
      </ul>
    </div>

    <div class="tj-cards__bricks tj-cards__bricks--bot" aria-hidden="true">
      <BrickRow variant="marquee" tone="copper" rows={1} size="sm" />
    </div>
  </section>
  </div>

  <section class="cta-strip section--dark">
    <div class="container cta-strip__inner">
      <p class="kicker kicker--light">Klar for å starte?</p>
      <h2>La oss <em>se på jobben</em>.</h2>
      <div class="cta-strip__btns">
        <a href="/kontakt" class="btn btn--primary btn--lg">Kontakt oss</a>
        <a href="tel:+4795523763" class="btn btn--ghost btn--lg">Ring 955 23 763</a>
      </div>
    </div>
  </section>
</main>

</Layout>
