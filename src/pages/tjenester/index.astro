---
import Layout from '../../layouts/Layout.astro';
import { getTjenester } from '../../lib/sanity';

const tjenester = await getTjenester();
---
<Layout
  title="Tjenester — Murmester Henriksen AS"
  description="Mestermurens domene strekker seg fra grunnmur og forblending til antikvarisk kalkrestaurering."
  activePage="tjenester"
>

<main>
  <section class="subhero" style="--subhero-img: url('/assets/projects/project-02.jpg');">
    <div class="container subhero__inner">
      <p class="subhero__crumbs">
        <a href="/">Hjem</a>
        <span aria-hidden="true">/</span>
        <span>Tjenester</span>
      </p>
      <p class="kicker kicker--light">Faget</p>
      <h1>Tjenester</h1>
      <p class="subhero__lede">
        Mestermurens domene strekker seg fra grunnmur og forblending til
        antikvarisk kalkrestaurering. Velg et fagområde for å se hvordan vi
        arbeider innenfor det.
      </p>
    </div>
  </section>

  <section class="tj-grid">
    <div class="container tj-grid__inner">
      {tjenester.map((t) => (
        <a class="tj-card" href={`/tjenester/${t.slug.current}`}>
          <span class="tj-card__icon" aria-hidden="true">{t.nummer}</span>
          <h3 class="tj-card__title" set:html={t.tittel} />
          {t.kortLede && <p class="tj-card__lede">{t.kortLede}</p>}
          <span class="tj-card__cta">Mer info</span>
        </a>
      ))}
    </div>
  </section>

  <section class="cta-strip section--dark">
    <div class="container cta-strip__inner">
      <p class="kicker kicker--light">Klar for å starte?</p>
      <h2>La oss <em>se på jobben</em>.</h2>
      <p class="cta-strip__lede">Vi gir et tydelig, skriftlig prisanslag. Uforpliktende.</p>
      <div class="cta-strip__btns">
        <a href="/kontakt" class="btn btn--primary btn--lg">Be om prisantydning</a>
        <a href="tel:+4795523763" class="btn btn--ghost btn--lg">Ring 955 23 763</a>
      </div>
    </div>
  </section>
</main>

</Layout>
