---
import Layout from '../../layouts/Layout.astro';
import { KATEGORIER } from '../../lib/kategorier';
---
<Layout
  title="Tjenester — Murmester Henriksen AS"
  description="Murmester Henriksen AS leverer fem hovedfag innen muring: muring, puss, ildsted og skorstein, flis/våtrom/betong, og restaurering."
  activePage="tjenester"
>

<main>
  <!-- Cinematic hero med ekte prosjektbilde + dramatic overlay -->
  <section class="tj-hero">
    <div class="tj-hero__bg" style="--hero-img: url('/assets/projects/project-06.jpg');"></div>
    <div class="container tj-hero__inner">
      <p class="subhero__crumbs">
        <a href="/">Hjem</a>
        <span aria-hidden="true">/</span>
        <span>Tjenester</span>
      </p>
      <p class="kicker kicker--light">Faget</p>
      <h1 class="tj-hero__h1">
        Murmesterens <em>fem fag</em>
      </h1>
      <p class="tj-hero__lede">
        Fra grunnmur og teglforblending til antikvarisk kalkrestaurering —
        alt utført av samme mester, fra første befaring til ferdig fuge.
      </p>
      <div class="tj-hero__stripe" aria-hidden="true">
        <span></span><span></span>
      </div>
    </div>
  </section>

  <!-- Magazine-style alternerende stretched cards -->
  <section class="tj-mag">
    <div class="container">
      {KATEGORIER.map((k, i) => (
        <article class={`tj-mag__card scroll-fade ${i % 2 === 1 ? 'tj-mag__card--rev' : ''}`}>
          <a class="tj-mag__media" href={`/tjenester/${k.slug}`} aria-label={k.tittel}>
            <img src={k.heroBilde} alt="" loading="lazy" decoding="async" />
            <span class="tj-mag__media-num" aria-hidden="true">{k.nummer}</span>
            <span class="tj-mag__media-overlay"></span>
          </a>
          <div class="tj-mag__body">
            <p class="tj-mag__eyebrow">Fagområde {k.nummer}</p>
            <h2 class="tj-mag__title">
              <a href={`/tjenester/${k.slug}`}>{k.tittel}</a>
            </h2>
            <p class="tj-mag__lede">{k.kortLede}</p>
            <p class="tj-mag__intro">{k.introTekst}</p>
            <ul class="tj-mag__list">
              {k.underkategorier.slice(0, 6).map((u) => (
                <li>{u.navn}</li>
              ))}
              {k.underkategorier.length > 6 && (
                <li class="tj-mag__list-more">+ {k.underkategorier.length - 6} til</li>
              )}
            </ul>
            <a class="tj-mag__cta" href={`/tjenester/${k.slug}`}>
              Se hva vi leverer
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="cta-strip section--dark">
    <div class="container cta-strip__inner">
      <p class="kicker kicker--light">Klar for å starte?</p>
      <h2>La oss <em>se på jobben</em>.</h2>
      <p class="cta-strip__lede">Vi gir et tydelig, skriftlig prisanslag. Uforpliktende.</p>
      <div class="cta-strip__btns">
        <a href="/kontakt" class="btn btn--primary btn--lg">Be om prisantydning</a>
        <a href="tel:+4795523763" class="btn btn--ghost btn--lg">Ring 955 23 763</a>
      </div>
    </div>
  </section>
</main>

</Layout>
