---
import Layout from '../../layouts/Layout.astro';
import { KATEGORIER } from '../../lib/kategorier';
---
<Layout
  title="Tjenester — Murmester Henriksen AS"
  description="Murmester Henriksen AS leverer fem hovedfag innen muring: muring, puss, ildsted og skorstein, flis/våtrom/betong, og restaurering."
  activePage="tjenester"
>

<main>
  <section class="subhero" style="--subhero-img: url('/assets/projects/project-02.jpg');">
    <div class="container subhero__inner">
      <p class="subhero__crumbs">
        <a href="/">Hjem</a>
        <span aria-hidden="true">/</span>
        <span>Tjenester</span>
      </p>
      <p class="kicker kicker--light">Faget</p>
      <h1>Tjenester</h1>
      <p class="subhero__lede">
        Murmesterens domene strekker seg fra grunnmur og forblending til
        antikvarisk kalkrestaurering. Velg et fagområde for å se hva vi
        leverer innenfor det.
      </p>
    </div>
  </section>

  <section class="tj-grid">
    <div class="container tj-grid__inner">
      {KATEGORIER.map((k) => (
        <a class="tj-card" href={`/tjenester/${k.slug}`}>
          <span class="tj-card__icon" aria-hidden="true">{k.nummer}</span>
          <h3 class="tj-card__title">{k.tittel}</h3>
          <p class="tj-card__lede">{k.kortLede}</p>
          <span class="tj-card__cta">Se hva vi leverer</span>
        </a>
      ))}
    </div>
  </section>

  <section class="cta-strip section--dark">
    <div class="container cta-strip__inner">
      <p class="kicker kicker--light">Klar for å starte?</p>
      <h2>La oss <em>se på jobben</em>.</h2>
      <p class="cta-strip__lede">Vi gir et tydelig, skriftlig prisanslag. Uforpliktende.</p>
      <div class="cta-strip__btns">
        <a href="/kontakt" class="btn btn--primary btn--lg">Be om prisantydning</a>
        <a href="tel:+4795523763" class="btn btn--ghost btn--lg">Ring 955 23 763</a>
      </div>
    </div>
  </section>
</main>

</Layout>
