---
import Layout from '../../layouts/Layout.astro';
import BrickRow from '../../components/BrickRow.astro';
import FagShield from '../../components/FagShield.astro';
import { KATEGORIER } from '../../lib/kategorier';

export async function getStaticPaths() {
  return KATEGORIER.map((k) => ({
    params: { slug: k.slug },
    props: { kategori: k },
  }));
}

const { kategori } = Astro.props;
const sosken = KATEGORIER.filter((k) => k.slug !== kategori.slug);

function formatPris(u: { prisFra?: string; prisTil?: string; prisEnhet?: string }): string | null {
  if (!u.prisFra && !u.prisTil) return null;
  const enhet = u.prisEnhet ? ` ${u.prisEnhet}` : '';
  if (u.prisFra && u.prisTil) return `${u.prisFra}–${u.prisTil}${enhet}`;
  if (u.prisFra) return `fra ${u.prisFra}${enhet}`;
  if (u.prisTil) return `opp til ${u.prisTil}${enhet}`;
  return null;
}

const SHIELD_PATH = "M 1 0.4521 C 1 0.5468, 0.9734 0.6349, 0.9208 0.7132 C 0.8794 0.7761, 0.8205 0.8331, 0.7468 0.8829 C 0.6367 0.9573, 0.5267 0.9924, 0.5001 1 C 0.4735 0.9924, 0.3634 0.9573, 0.2533 0.8829 C 0.1797 0.8331, 0.1207 0.7761, 0.0793 0.7132 C 0.0267 0.6349, 0 0.5468, 0 0.4521 L 0 0.1352 C 0.0245 0.133, 0.0736 0.1275, 0.1395 0.1144 C 0.2587 0.0909, 0.3835 0.0514, 0.5001 0 C 0.6166 0.0514, 0.7414 0.0909, 0.8605 0.1144 C 0.9272 0.1281, 0.9755 0.133, 1 0.1352 Z";
---
<Layout
  title={`${kategori.tittel} — Murmester Henriksen AS`}
  description={kategori.kortLede}
  activePage="tjenester"
>

<main>
  <!-- SVG-clipPath for skjold-shapes -->
  <svg width="0" height="0" style="position:absolute" aria-hidden="true">
    <defs>
      <clipPath id="shieldClip" clipPathUnits="objectBoundingBox">
        <path d={SHIELD_PATH} />
      </clipPath>
    </defs>
  </svg>

  <!-- 1. Hero på murvegg-bg med fag-skjold som visuell anker -->
  <section class="fag-hero">
    <div class="fag-hero__bricks fag-hero__bricks--top" aria-hidden="true">
      <BrickRow variant="marquee" tone="copper" rows={1} size="sm" />
    </div>

    <div class="container fag-hero__inner">
      <p class="fag-hero__crumbs">
        <a href="/">Hjem</a>
        <span aria-hidden="true">/</span>
        <a href="/tjenester/">Tjenester</a>
        <span aria-hidden="true">/</span>
        <span>{kategori.tittel}</span>
      </p>

      <div class="fag-hero__emblem">
        <svg class="fag-hero__shield" viewBox="0 0 156 200" shape-rendering="geometricPrecision" aria-hidden="true">
          <path fill="rgba(245,241,234,.04)" stroke="rgba(245,241,234,.75)" stroke-width="2.5" stroke-linejoin="round" d="M 156 90.42 C 156 109.36, 151.85 126.98, 143.64 142.64 C 137.19 155.22, 128 166.62, 116.5 176.58 C 99.33 191.46, 82.17 198.48, 78.02 200 C 73.87 198.48, 56.69 191.46, 39.51 176.58 C 28.03 166.62, 18.83 155.22, 12.37 142.64 C 4.17 126.98, 0 109.36, 0 90.42 L 0 27.04 C 3.82 26.6, 11.48 25.5, 21.76 22.88 C 40.36 18.18, 59.83 10.28, 78.02 0 C 96.19 10.28, 115.66 18.18, 134.24 22.88 C 144.64 25.62, 152.18 26.6, 156 27.04 Z" />
        </svg>
        <div class="fag-hero__icon">
          <FagShield slug={kategori.slug} />
        </div>
      </div>

      <p class="kicker kicker--light">Fagområde {kategori.nummer}</p>
      <h1 class="fag-hero__h1">{kategori.tittel}</h1>
      <p class="fag-hero__lede">{kategori.kortLede}</p>
    </div>

    <div class="fag-hero__bricks fag-hero__bricks--bot" aria-hidden="true">
      <BrickRow variant="marquee" tone="copper" rows={1} size="sm" />
    </div>
  </section>

  <!-- Pussvegg-stage: leveranser + andre fagområder -->
  <div class="fag-stage">

  <!-- 2. Leveranser tabell -->
  <section class="leveranser">
    <div class="container">
      <div class="leveranser__head">
        <h2 class="leveranser__h2">Det vi leverer innen <em>{kategori.tittel.toLowerCase()}</em></h2>
        <p class="leveranser__note">Pris på forespørsel</p>
      </div>

      <ul class="leveranser__list">
        {kategori.underkategorier.map((u, i) => {
          const pris = formatPris(u);
          const harInfo = Boolean(u.infoTekst);
          return (
            <li class="leveranse">
              <details class="leveranse__details">
                <summary class="leveranse__summary">
                  <span class="leveranse__num" aria-hidden="true">{String(i + 1).padStart(2, '0')}</span>
                  <span class="leveranse__main">
                    <span class="leveranse__navn">{u.navn}</span>
                  </span>
                  <span class="leveranse__meta">
                    {pris && <span class="leveranse__pris">{pris}</span>}
                    {harInfo && <span class="leveranse__expand" aria-hidden="true">↓</span>}
                  </span>
                </summary>
                {(harInfo || u.prisNote) && (
                  <div class="leveranse__body">
                    {harInfo && (
                      <div class="leveranse__info">
                        <p>{u.infoTekst}</p>
                      </div>
                    )}
                    {u.prisNote && (
                      <p class="leveranse__prisnote"><strong>Om prisen:</strong> {u.prisNote}</p>
                    )}
                    <a class="leveranse__cta" href={`/kontakt?fag=${kategori.slug}&leveranse=${encodeURIComponent(u.navn)}`}>
                      Spør om denne leveransen
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                    </a>
                  </div>
                )}
              </details>
            </li>
          );
        })}
      </ul>

      <p class="leveranser__foot">
        Usikker på hva som passer? <a href="/kontakt">Ta kontakt</a> — vi finner ut av det sammen.
      </p>
    </div>
  </section>

  <!-- 4. Andre fagområder som mini-skjold -->
  <section class="andre-fag">
    <div class="container">
      <p class="kicker">Utforsk videre</p>
      <h2 class="andre-fag__h2">Andre <em>fagområder</em></h2>

      <ul class="andre-fag__list">
        {sosken.map((s) => (
          <li class="andre-fag__item">
            <a class="andre-fag__link" href={`/tjenester/${s.slug}`}>
              <div class="andre-fag__emblem">
                <svg class="andre-fag__shield" viewBox="0 0 156 200" shape-rendering="geometricPrecision" aria-hidden="true">
                  <path fill="#F2EAD8" stroke="rgba(190,84,0,.5)" stroke-width="3" stroke-linejoin="round" d="M 156 90.42 C 156 109.36, 151.85 126.98, 143.64 142.64 C 137.19 155.22, 128 166.62, 116.5 176.58 C 99.33 191.46, 82.17 198.48, 78.02 200 C 73.87 198.48, 56.69 191.46, 39.51 176.58 C 28.03 166.62, 18.83 155.22, 12.37 142.64 C 4.17 126.98, 0 109.36, 0 90.42 L 0 27.04 C 3.82 26.6, 11.48 25.5, 21.76 22.88 C 40.36 18.18, 59.83 10.28, 78.02 0 C 96.19 10.28, 115.66 18.18, 134.24 22.88 C 144.64 25.62, 152.18 26.6, 156 27.04 Z" />
                </svg>
                <div class="andre-fag__icon">
                  <FagShield slug={s.slug} />
                </div>
              </div>
              <span class="andre-fag__name">{s.tittel}</span>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>
  </div><!-- /.fag-stage -->

  <!-- 5. CTA-strip -->
  <section class="cta-strip section--dark">
    <div class="container cta-strip__inner">
      <p class="kicker kicker--light">Klar for å starte?</p>
      <h2>La oss <em>se på jobben</em>.</h2>
      <div class="cta-strip__btns">
        <a href="/kontakt" class="btn btn--primary btn--lg">Kontakt oss</a>
        <a href="tel:+4795523763" class="btn btn--ghost btn--lg">Ring 955 23 763</a>
      </div>
    </div>
  </section>
</main>

</Layout>
