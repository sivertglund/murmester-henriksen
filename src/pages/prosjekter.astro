---
import Layout from '../layouts/Layout.astro';
---
<Layout
  title="Prosjekter — Murmester Henriksen AS"
  description="Et utvalg arbeider fra Murmester Henriksen AS — teglforblending, puss, kalkrestaurering, peis og pipe i Vestfold."
  activePage="prosjekter"
>

<main>
  <section class="subhero">
    <div class="container subhero__inner">
      <p class="subhero__crumbs">
        <a href="/">Hjem</a>
        <span aria-hidden="true">/</span>
        <span>Prosjekter</span>
      </p>
      <p class="kicker kicker--light">Prosjekter</p>
      <h1>Et utvalg <em>arbeider</em>.</h1>
      <p class="subhero__lede">
        Et knippe oppdrag fra Vestfold — fra teglforblending og puss til
        kalkrestaurering og peis. Trenger du referanser innenfor et bestemt
        fagområde, ta kontakt så viser vi deg flere.
      </p>
    </div>
  </section>

  <section class="projects">
    <div class="container">
      <div class="projects__grid">
        <figure class="projects__item"><img src="/assets/projects/project-01.jpg" alt="Pussfasade på sokkel" loading="lazy" decoding="async" /></figure>
        <figure class="projects__item"><img src="/assets/projects/project-02.jpg" alt="Murverk" loading="lazy" decoding="async" /></figure>
        <figure class="projects__item"><img src="/assets/projects/project-03.jpg" alt="Restaurert murverk" loading="lazy" decoding="async" /></figure>
        <figure class="projects__item"><img src="/assets/projects/project-04.jpg" alt="Peis" loading="lazy" decoding="async" /></figure>
        <figure class="projects__item"><img src="/assets/projects/project-05.jpg" alt="Pipe-rehabilitering" loading="lazy" decoding="async" /></figure>
        <figure class="projects__item"><img src="/assets/projects/project-06.jpg" alt="Teglforblending" loading="lazy" decoding="async" /></figure>
        <figure class="projects__item"><img src="/assets/projects/project-07.jpg" alt="Flislegging" loading="lazy" decoding="async" /></figure>
        <figure class="projects__item"><img src="/assets/projects/project-08.jpg" alt="Sparkling og gulvavretting" loading="lazy" decoding="async" /></figure>
        <figure class="projects__item"><img src="/assets/projects/project-09.jpg" alt="Skifer og naturstein" loading="lazy" decoding="async" /></figure>
        <figure class="projects__item"><img src="/assets/projects/project-10.jpg" alt="Murverk" loading="lazy" decoding="async" /></figure>
        <figure class="projects__item"><img src="/assets/projects/project-11.jpg" alt="Murverk" loading="lazy" decoding="async" /></figure>
        <figure class="projects__item"><img src="/assets/projects/project-12.jpg" alt="Elementpipe" loading="lazy" decoding="async" /></figure>
      </div>

      <p class="projects__note">
        Vil du se referanser for et bestemt fagområde — pipe, kalk, tegl eller flis?
        <a href="/kontakt">Ta kontakt</a> så viser vi deg flere.
      </p>
    </div>
  </section>
</main>

</Layout>
