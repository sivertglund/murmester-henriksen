---
import Layout from '../layouts/Layout.astro';
import { getProsjekter, prosjektImageSrc } from '../lib/sanity';

const prosjekter = await getProsjekter();
---
<Layout
  title="Prosjekter — Murmester Henriksen AS"
  description="Et utvalg arbeider fra Murmester Henriksen AS — teglforblending, puss, kalkrestaurering, peis og pipe i Vestfold."
  activePage="prosjekter"
>

<main>
  <section class="subhero">
    <div class="container subhero__inner">
      <p class="subhero__crumbs">
        <a href="/">Hjem</a>
        <span aria-hidden="true">/</span>
        <span>Prosjekter</span>
      </p>
      <p class="kicker kicker--light">Prosjekter</p>
      <h1>Et utvalg <em>arbeider</em>.</h1>
      <p class="subhero__lede">
        Et knippe oppdrag fra Vestfold — fra teglforblending og puss til
        kalkrestaurering og peis. Trenger du referanser innenfor et bestemt
        fagområde, ta kontakt så viser vi deg flere.
      </p>
    </div>
  </section>

  <section class="projects">
    <div class="container">
      <div class="projects__grid">
        {prosjekter.map((p) => (
          <figure class="projects__item">
            <img src={prosjektImageSrc(p)} alt={p.tittel} loading="lazy" decoding="async" />
          </figure>
        ))}
      </div>

      <p class="projects__note">
        Vil du se referanser for et bestemt fagområde — pipe, kalk, tegl eller flis?
        <a href="/kontakt">Ta kontakt</a> så viser vi deg flere.
      </p>
    </div>
  </section>
</main>

</Layout>
